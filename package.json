{
  "name": "edugrade",
  "version": "1.0.0",
  "description": "AI-powered answer sheet analyzer for schools",
  "type": "module",
  "scripts": {
    "build": "cd student-analyzer && npm install && npm run build && cd ../backend && npm install",
    "start": "cd backend && node server.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/smoke.spec.js",
    "test:api": "playwright test tests/api.spec.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
