# ── Staging environment variables ────────────────────────────────────────────
# Copy to .env on your staging Render service.
# Use a SEPARATE Supabase project for staging (free tier: 2 projects included).

ANTHROPIC_API_KEY=sk-ant-...

# Staging Supabase project (different from production!)
SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Same admin user ID as prod (your own UUID) — or create a staging admin
ADMIN_USER_ID=7f3cd39a-ec15-4053-9c6a-0afad38d2f46

# Allow local dev + Vercel preview URLs
CORS_ORIGINS=http://localhost:5173,https://YOUR_VERCEL_PREVIEW_URL.vercel.app

SERVE_FRONTEND=false

# ── Langfuse (optional — uses same project, tag traces as "staging") ──────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
