{
  "name": "compliance-ai-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "langfuse": "^3.35.0",
    "multer": "^1.4.5-lts.1",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "supertest": "^7.0.0",
    "vitest": "^2.0.0"
  },
  "vitest": {
    "setupFiles": [
      "./tests/setup.js"
    ],
    "environment": "node",
    "testTimeout": 15000
  }
}
